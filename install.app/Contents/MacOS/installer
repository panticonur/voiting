#!/bin/bash
# Entry point of install.app — runs install.command from the folder that contains install.app.

set -e

# Path to install.app/Contents/MacOS/installer
SELF="$0"
# Go up: MacOS -> Contents -> install.app -> parent folder of install.app
APP_DIR="$(cd "$(dirname "$SELF")/../.." && pwd)"
PARENT_DIR="$(dirname "$APP_DIR")"

SCRIPT="$PARENT_DIR/install.command"

if [ ! -f "$SCRIPT" ]; then
    osascript -e "display dialog \"install.command not found next to install.app:\n$SCRIPT\" buttons {\"OK\"} default button 1 with icon stop"
    exit 1
fi

# Make sure install.command is executable (the bit may be lost after copy from Windows / unzip).
chmod +x "$SCRIPT" 2>/dev/null || true

# Open install.command in a new Terminal window so the user can see the output and any prompts.
osascript <<EOF
tell application "Terminal"
    activate
    do script "\"$SCRIPT\""
end tell
EOF
