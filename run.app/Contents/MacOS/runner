#!/bin/bash
# Entry point of run.app — runs run.command from the folder that contains run.app.

set -e

# Path to run.app/Contents/MacOS/runner
SELF="$0"
# Go up: MacOS -> Contents -> run.app -> parent folder of run.app
APP_DIR="$(cd "$(dirname "$SELF")/../.." && pwd)"
PARENT_DIR="$(dirname "$APP_DIR")"

SCRIPT="$PARENT_DIR/run.command"

if [ ! -f "$SCRIPT" ]; then
    osascript -e "display dialog \"run.command not found next to run.app:\n$SCRIPT\" buttons {\"OK\"} default button 1 with icon stop"
    exit 1
fi

# Make sure run.command is executable (the bit may be lost after copy from Windows / unzip).
chmod +x "$SCRIPT" 2>/dev/null || true

# Open run.command in a new Terminal window so the user can see the output.
osascript <<EOF
tell application "Terminal"
    activate
    do script "\"$SCRIPT\""
end tell
EOF
